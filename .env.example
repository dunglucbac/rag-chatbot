# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=secret
DB_NAME=ragchatbot

# RabbitMQ
RABBITMQ_URL=amqp://app:app123@localhost:5672
RABBITMQ_EXCHANGE=ingest.topic
RABBITMQ_IMAGE_QUEUE=ingest.image.queue
RABBITMQ_PDF_QUEUE=ingest.pdf.queue

# LLM — "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ANTHROPIC_BASE_URL=...

# Embeddings — currently only "openai" supported
EMBEDDING_PROVIDER=openai

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.com

# Web search
TAVILY_API_KEY=tvly-...

PORT=3000
